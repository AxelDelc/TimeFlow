<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %> — TimeFlow</title>
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/layout.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/employee.css">
</head>
<body>
<div class="layout">

    <aside class="sidebar">
        <div class="sidebar-brand">
            <span class="brand-logo">TF</span>
            <span class="brand-name">TimeFlow</span>
        </div>

        <nav class="sidebar-nav">
            <% if (user.role === 'admin') { %>
            <a href="/admin" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                Tableau de bord
            </a>
            <a href="/admin/employees" class="nav-item <%= currentPage === 'employees' ? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Salariés
            </a>
            <a href="/admin/sessions" class="nav-item <%= currentPage === 'sessions' ? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Pointages
            </a>
            <% } else { %>
            <a href="/employee" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                Mon espace
            </a>
            <a href="/employee/schedule" class="nav-item <%= currentPage === 'schedule' ? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Mon planning
            </a>
            <% } %>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <span class="user-avatar"><%= user.name.charAt(0).toUpperCase() %></span>
                <span class="user-name"><%= user.name %></span>
            </div>
            <a href="/logout" class="logout-btn" title="Déconnexion">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </a>
        </div>
    </aside>

    <div class="main-wrapper">
        <header class="top-bar">
            <h1 class="page-title"><%= pageTitle %></h1>
        </header>
        <main class="content">
