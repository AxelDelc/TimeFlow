<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion — TimeFlow</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<div class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <div class="login-logo-mark">TF</div>
            <span class="login-logo-text">TimeFlow</span>
        </div>

        <h2>Connexion</h2>

        <% if (typeof error !== 'undefined') { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>

        <form method="POST" action="/login">
            <div class="form-group">
                <label for="email">Adresse email</label>
                <input id="email" name="email" type="email" placeholder="email@example.com" required autofocus />
            </div>
            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input id="password" name="password" type="password" placeholder="••••••••" required />
            </div>
            <div class="form-footer">
                <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Se connecter</button>
            </div>
        </form>
    </div>
</div>
</body>
</html>