<%- include('../layout/header', { pageTitle: 'Mon planning', currentPage: 'schedule', user: user }) %>

<%
const HOUR_START = 7;
const HOUR_END = 20;
const HOUR_HEIGHT = 64;

function utcDateStr(d) {
    return d.getUTCFullYear() + '-' + String(d.getUTCMonth()+1).padStart(2,'0') + '-' + String(d.getUTCDate()).padStart(2,'0');
}

const prevWeek = new Date(weekStart); prevWeek.setUTCDate(weekStart.getUTCDate() - 7);
const nextWeek = new Date(weekStart); nextWeek.setUTCDate(weekStart.getUTCDate() + 7);
const weekEnd  = new Date(weekStart); weekEnd.setUTCDate(weekStart.getUTCDate() + 6);
const prevWeekStr = utcDateStr(prevWeek);
const nextWeekStr = utcDateStr(nextWeek);
const weekLabel = weekStart.toLocaleDateString('fr-FR', { timeZone: 'UTC' }) + ' – ' + weekEnd.toLocaleDateString('fr-FR', { timeZone: 'UTC' });
const todayStr = utcDateStr(new Date());

const days = [];
for (let i = 0; i < 7; i++) {
    const d = new Date(weekStart);
    d.setUTCDate(weekStart.getUTCDate() + i);
    days.push(d);
}

const slotsByDay = {};
days.forEach(d => { slotsByDay[utcDateStr(d)] = []; });
timeSchedule.forEach(slot => {
    const key = utcDateStr(new Date(slot.date));
    if (slotsByDay[key]) slotsByDay[key].push(slot);
});
%>

<div class="card card--mb">
    <div class="card-header">
        <a href="/employee/schedule?weekStart=<%= prevWeekStr %>" class="btn btn-ghost btn-sm">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            Précédente
        </a>
        <span class="card-title">Semaine du <%= weekLabel %></span>
        <a href="/employee/schedule?weekStart=<%= nextWeekStr %>" class="btn btn-ghost btn-sm">
            Suivante
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
    </div>

    <div class="sc-calendar">
        <div class="sc-header">
            <div></div>
            <% days.forEach(day => { %>
            <div class="sc-day-header <%= utcDateStr(day) === todayStr ? 'today' : '' %>">
                <%= day.toLocaleDateString('fr-FR', { timeZone: 'UTC', weekday: 'short', day: 'numeric', month: 'short' }) %>
            </div>
            <% }) %>
        </div>
        <div class="sc-body">
            <div class="sc-time-col">
                <% for (let h = HOUR_START; h <= HOUR_END; h++) { %>
                <div class="sc-hour-label" style="height:<%= HOUR_HEIGHT %>px"><%= String(h).padStart(2,'0') %>h</div>
                <% } %>
            </div>
            <% days.forEach(day => { %>
            <div class="sc-day-col"
                style="height:<%= (HOUR_END - HOUR_START) * HOUR_HEIGHT %>px">
                <% for (let h = 0; h < (HOUR_END - HOUR_START); h++) { %>
                <div class="sc-grid-line" style="top:<%= h * HOUR_HEIGHT %>px"></div>
                <% } %>
                <% slotsByDay[utcDateStr(day)].forEach(slot => {
                    const s = new Date(slot.startTime);
                    const e = new Date(slot.endTime);
                    const top = (s.getUTCHours() + s.getUTCMinutes()/60 - HOUR_START) * HOUR_HEIGHT;
                    const height = Math.max((e.getUTCHours() + e.getUTCMinutes()/60 - s.getUTCHours() - s.getUTCMinutes()/60) * HOUR_HEIGHT, 20);
                    const startStr = s.toLocaleTimeString('fr-FR', { timeZone: 'UTC', hour: '2-digit', minute: '2-digit' });
                    const endStr = e.toLocaleTimeString('fr-FR', { timeZone: 'UTC', hour: '2-digit', minute: '2-digit' });
                    const dateStr = utcDateStr(new Date(slot.date));
                %>
                <div class="sc-slot sc-slot--<%= slot.type %>"
                    style="top:<%= top %>px;height:<%= height %>px"
                    data-slot-id="<%= slot.id %>"
                    data-start="<%= startStr %>"
                    data-end="<%= endStr %>"
                    data-date="<%= dateStr %>">
                    <span class="sc-slot-time"><%= startStr %> – <%= endStr %></span>
                    <span class="sc-slot-label"><%= slot.type === 'work' ? 'Travail' : 'Pause' %></span>
                </div>
                <% }) %>
            </div>
            <% }) %>
        </div>
    </div>
</div>

<div class="card card--mb">
    <div class="card-header"><span class="card-title">Déclarer des heures sup</span></div>
    <div class="card-body">
        <div id="overtime-error" class="alert alert-error" style="display:none"></div>
        <form id="overtime-form" style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr auto;gap:12px;align-items:end">
            <div class="form-group" style="margin:0">
                <label class="form-label">Date</label>
                <input type="date" name="date" class="form-input" required>
            </div>
            <div class="form-group" style="margin:0">
                <label class="form-label">Début</label>
                <input type="time" name="startTime" class="form-input" required>
            </div>
            <div class="form-group" style="margin:0">
                <label class="form-label">Fin</label>
                <input type="time" name="endTime" class="form-input" required>
            </div>
            <div class="form-group" style="margin:0">
                <label class="form-label">Motif</label>
                <select name="reason" class="form-input" required>
                    <option value="colleague_abscence">Absence collègue</option>
                    <option value="client_issue">Problème client</option>
                    <option value="manager_request">Demande manager</option>
                    <option value="other">Autre</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Déclarer</button>
        </form>
    </div>
</div>

<!-- Modale : demande de modification -->
<dialog id="modal-change">
    <div class="modal-header">
        <span class="modal-title">Demander une modification</span>
        <button class="modal-close" onclick="document.getElementById('modal-change').close()">×</button>
    </div>
    <div class="modal-body">
        <p id="modal-change-info" style="color:#475569;font-size:13px;margin-bottom:16px"></p>
        <div id="change-request-error" class="alert alert-error" style="display:none"></div>
        <form id="change-request-form">
            <input type="hidden" name="originalSlotId" id="originalSlotId">
            <div class="form-group">
                <label class="form-label">Nouvelle date</label>
                <input type="date" name="newDate" class="form-input" required>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Nouveau début</label>
                    <input type="time" name="newStartTime" class="form-input" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Nouvelle fin</label>
                    <input type="time" name="newEndTime" class="form-input" required>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Message pour l'admin</label>
                <textarea name="employeeMessage" class="form-input" rows="2"></textarea>
            </div>
        </form>
    </div>
    <div class="modal-footer">
        <button class="btn btn-ghost" onclick="document.getElementById('modal-change').close()">Annuler</button>
        <button class="btn btn-primary" id="btn-send-change">Envoyer la demande</button>
    </div>
</dialog>

<script src="/js/employee-schedule.js"></script>

<%- include('../layout/footer') %>
