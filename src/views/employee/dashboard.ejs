<%- include('../layout/header', { pageTitle: 'Mon espace', currentPage: 'dashboard', user: user }) %>

<div class="punch-grid punch-wrapper">
    <form method="POST" action="/employee/start">
        <button class="punch-btn punch-in">Pointer entrée</button>
    </form>
    <form method="POST" action="/employee/end">
        <button class="punch-btn punch-out">Pointer sortie</button>
    </form>
</div>

<div class="card sessions-card">
    <div class="card-header">
        <span class="card-title">Mes pointages</span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Entrée</th>
                    <th>Sortie</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                <% if (sessions.length === 0) { %>
                    <tr><td colspan="3" class="empty-state">Aucun pointage enregistré</td></tr>
                <% } %>
                <% sessions.forEach(s => { %>
                    <tr>
                        <td><%= s.start_time %></td>
                        <td><%= s.end_time || '—' %></td>
                        <td>
                            <% if (!s.end_time) { %>
                                <span class="badge badge-green"><span class="badge-dot"></span>En cours</span>
                            <% } else { %>
                                <span class="badge badge-gray">Terminé</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../layout/footer') %>