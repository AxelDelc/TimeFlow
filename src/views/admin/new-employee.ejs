<%- include('../layout/header', { pageTitle: 'Nouveau salarié', currentPage: 'employees', user: user }) %>

<div class="card card--narrow">
    <div class="card-header">
        <span class="card-title">Créer un compte salarié</span>
    </div>
    <div class="card-body">

        <% if (typeof error !== 'undefined') { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>

        <form method="POST">
            <div class="form-group">
                <label for="name">Nom complet</label>
                <input id="name" name="name" type="text" placeholder="Jean Dupont" required />
            </div>
            <div class="form-group">
                <label for="email">Adresse email</label>
                <input id="email" name="email" type="email" placeholder="jean@example.com" required />
            </div>
            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input id="password" name="password" type="password" placeholder="••••••••" required />
            </div>
            <div class="form-footer">
                <button type="submit" class="btn btn-primary">Créer le compte</button>
                <a href="/admin/employees" class="btn btn-ghost">Annuler</a>
            </div>
        </form>

    </div>
</div>

<%- include('../layout/footer') %>
