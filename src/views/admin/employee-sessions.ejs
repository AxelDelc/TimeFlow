<%- include('../layout/header', { pageTitle: 'Pointages — ' + employee.name, currentPage: 'employees', user: user }) %>

<div style="margin-bottom:16px;">
    <a href="/admin/employees" class="btn btn-ghost btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;"><polyline points="15 18 9 12 15 6"/></svg>
        Retour aux salariés
    </a>
</div>

<div class="card" style="margin-bottom:16px;padding:0;">
    <div class="card-body" style="display:flex;align-items:center;gap:14px;">
        <div class="user-avatar" style="background:#1e40af;color:#bfdbfe;width:44px;height:44px;font-size:16px;font-weight:700;border-radius:50%;display:flex;align-items:center;justify-content:center;">
            <%= employee.name.charAt(0).toUpperCase() %>
        </div>
        <div>
            <div style="font-weight:600;font-size:15px;color:#0f172a;"><%= employee.name %></div>
            <div style="font-size:12.5px;color:#64748b;"><%= employee.email %></div>
        </div>
        <div style="margin-left:auto;">
            <% if (employee.is_active) { %>
                <span class="badge badge-green"><span class="badge-dot"></span>Actif</span>
            <% } else { %>
                <span class="badge badge-red">Désactivé</span>
            <% } %>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">Historique des pointages</span>
        <span class="badge badge-blue"><%= sessions.length %> pointage<%= sessions.length > 1 ? 's' : '' %></span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Entrée</th>
                    <th>Sortie</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                <% if (sessions.length === 0) { %>
                    <tr><td colspan="4" class="empty-state">Aucun pointage pour ce salarié</td></tr>
                <% } %>
                <% sessions.forEach((s, i) => { %>
                    <tr>
                        <td style="color:#94a3b8;">#<%= s.id %></td>
                        <td><%= s.start_time %></td>
                        <td><%= s.end_time || '—' %></td>
                        <td>
                            <% if (!s.end_time) { %>
                                <span class="badge badge-green"><span class="badge-dot"></span>En cours</span>
                            <% } else { %>
                                <span class="badge badge-gray">Terminé</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../layout/footer') %>
