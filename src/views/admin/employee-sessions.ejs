<%- include('../layout/header', { pageTitle: 'Pointages — ' + employee.name, currentPage: 'employees', user: user }) %>

<div class="mb-4">
    <a href="/admin/employees" class="btn btn-ghost btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour aux salariés
    </a>
</div>

<div class="card card--mb">
    <div class="card-body profile-header">
        <div class="user-avatar avatar-blue avatar-lg">
            <%= employee.name.charAt(0).toUpperCase() %>
        </div>
        <div>
            <div class="profile-name"><%= employee.name %></div>
            <div class="profile-email"><%= employee.email %></div>
        </div>
        <div class="ml-auto">
            <% if (employee.is_active) { %>
                <span class="badge badge-green"><span class="badge-dot"></span>Actif</span>
            <% } else { %>
                <span class="badge badge-red">Désactivé</span>
            <% } %>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">Historique des pointages</span>
        <span class="badge badge-blue"><%= sessions.length %> pointage<%= sessions.length > 1 ? 's' : '' %></span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Entrée</th>
                    <th>Sortie</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                <% if (sessions.length === 0) { %>
                    <tr><td colspan="4" class="empty-state">Aucun pointage pour ce salarié</td></tr>
                <% } %>
                <% sessions.forEach((s, i) => { %>
                    <tr>
                        <td class="text-subtle">#<%= s.id %></td>
                        <td><%= s.start_time %></td>
                        <td><%= s.end_time || '—' %></td>
                        <td>
                            <% if (!s.end_time) { %>
                                <span class="badge badge-green"><span class="badge-dot"></span>En cours</span>
                            <% } else { %>
                                <span class="badge badge-gray">Terminé</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../layout/footer') %>
