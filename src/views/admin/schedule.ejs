<%- include('../layout/header', { pageTitle: 'Planning — ' + employee.name, currentPage: 'employees', user: user }) %>

<%
const HOUR_START = 7;
const HOUR_END = 20;
const HOUR_HEIGHT = 64;

const prevWeek = new Date(weekStart);
prevWeek.setDate(prevWeek.getDate() - 7);
const nextWeek = new Date(weekStart);
nextWeek.setDate(nextWeek.getDate() + 7);
const weekEnd = new Date(weekStart);
weekEnd.setDate(weekStart.getDate() + 6);
const prevWeekStr = prevWeek.toISOString().split('T')[0];
const nextWeekStr = nextWeek.toISOString().split('T')[0];
const weekLabel = weekStart.toLocaleDateString('fr-FR') + ' – ' + weekEnd.toLocaleDateString('fr-FR');
const today = new Date(); today.setHours(0,0,0,0);

const days = [];
for (let i = 0; i < 7; i++) {
    const d = new Date(weekStart);
    d.setDate(weekStart.getDate() + i);
    days.push(d);
}

const slotsByDay = {};
days.forEach(d => { slotsByDay[d.toDateString()] = []; });
timeSchedule.forEach(slot => {
    const key = new Date(slot.date).toDateString();
    if (slotsByDay[key]) slotsByDay[key].push(slot);
});
%>

<div class="mb-4">
    <a href="/admin/employees" class="btn btn-ghost btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour aux salariés
    </a>
</div>

<div class="card card--mb">
    <div class="card-body profile-header">
        <div class="user-avatar avatar-blue avatar-lg"><%= employee.name.charAt(0).toUpperCase() %></div>
        <div>
            <div class="profile-name"><%= employee.name %></div>
            <div class="profile-email"><%= employee.email %></div>
        </div>
        <div class="ml-auto">
            <% if (employee.isActive) { %>
                <span class="badge badge-green"><span class="badge-dot"></span>Actif</span>
            <% } else { %>
                <span class="badge badge-red">Désactivé</span>
            <% } %>
        </div>
    </div>
</div>

<div class="card card--mb">
    <div class="card-header">
        <a href="/admin/schedule/<%= employee.id %>?weekStart=<%= prevWeekStr %>" class="btn btn-ghost btn-sm">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            Précédente
        </a>
        <span class="card-title">Semaine du <%= weekLabel %></span>
        <a href="/admin/schedule/<%= employee.id %>?weekStart=<%= nextWeekStr %>" class="btn btn-ghost btn-sm">
            Suivante
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
    </div>

    <div class="sc-calendar">
        <div class="sc-header">
            <div></div>
            <% days.forEach(day => { %>
            <div class="sc-day-header <%= day.toDateString() === today.toDateString() ? 'today' : '' %>">
                <%= day.toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric', month: 'short' }) %>
            </div>
            <% }) %>
        </div>
        <div class="sc-body">
            <div class="sc-time-col">
                <% for (let h = HOUR_START; h <= HOUR_END; h++) { %>
                <div class="sc-hour-label" style="height:<%= HOUR_HEIGHT %>px"><%= String(h).padStart(2,'0') %>h</div>
                <% } %>
            </div>
            <% days.forEach(day => { %>
            <div class="sc-day-col" style="height:<%= (HOUR_END - HOUR_START) * HOUR_HEIGHT %>px">
                <% for (let h = 0; h < (HOUR_END - HOUR_START); h++) { %>
                <div class="sc-grid-line" style="top:<%= h * HOUR_HEIGHT %>px"></div>
                <% } %>
                <% slotsByDay[day.toDateString()].forEach(slot => {
                    const s = new Date(slot.startTime);
                    const e = new Date(slot.endTime);
                    const top = (s.getHours() + s.getMinutes()/60 - HOUR_START) * HOUR_HEIGHT;
                    const height = Math.max((e.getHours() + e.getMinutes()/60 - s.getHours() - s.getMinutes()/60) * HOUR_HEIGHT, 20);
                    const startStr = s.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
                    const endStr = e.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
                %>
                <div class="sc-slot sc-slot--<%= slot.type %>" style="top:<%= top %>px;height:<%= height %>px" title="<%= startStr %> – <%= endStr %>">
                    <span class="sc-slot-time"><%= startStr %> – <%= endStr %></span>
                    <span class="sc-slot-label"><%= slot.type === 'work' ? 'Travail' : 'Pause' %></span>
                    <button class="sc-slot-btn" onclick="deleteSlot(<%= slot.id %>)">Supprimer</button>
                </div>
                <% }) %>
            </div>
            <% }) %>
        </div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="card">
        <div class="card-header"><span class="card-title">Ajouter un créneau</span></div>
        <div class="card-body">
            <div id="slot-error" class="alert alert-error" style="display:none"></div>
            <form id="add-slot-form">
                <div class="form-group">
                    <label class="form-label">Date</label>
                    <input type="date" name="date" class="form-input" required>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Début</label>
                        <input type="time" name="startTime" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fin</label>
                        <input type="time" name="endTime" class="form-input" required>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Type</label>
                    <select name="type" class="form-input">
                        <option value="work">Travail</option>
                        <option value="break">Pause</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary w-full">Ajouter</button>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title">Contraintes</span></div>
        <div class="card-body">
            <form id="restrictions-form">
                <div class="form-group">
                    <label class="form-label">Heures hebdomadaires cibles</label>
                    <input type="number" name="weeklyHoursTarget" class="form-input" min="1" max="48" step="0.5"
                        value="<%= restrictions ? restrictions.weeklyHoursTarget : 35 %>">
                </div>
                <div class="form-group">
                    <label class="form-label">Heures consécutives max</label>
                    <input type="number" name="maxConsecutiveHours" class="form-input" min="1" max="12" step="0.5"
                        value="<%= restrictions ? restrictions.maxConsecutiveHours : 8 %>">
                </div>
                <div class="form-group">
                    <label class="form-label">Notes</label>
                    <textarea name="notes" class="form-input" rows="3"><%= restrictions ? (restrictions.notes || '') : '' %></textarea>
                </div>
                <button type="submit" class="btn btn-primary w-full">Enregistrer</button>
            </form>
        </div>
    </div>
</div>

<script>
const employeeId = <%= employee.id %>;

async function deleteSlot(slotId) {
    if (!confirm('Supprimer ce créneau ?')) return;
    const res = await fetch('/admin/schedule/slot/' + slotId, { method: 'DELETE' });
    if (res.ok) location.reload();
    else alert('Erreur lors de la suppression');
}

document.getElementById('add-slot-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    const errorEl = document.getElementById('slot-error');
    errorEl.style.display = 'none';
    const res = await fetch('/admin/schedule/' + employeeId + '/slot', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
    });
    if (res.ok) location.reload();
    else { const j = await res.json(); errorEl.textContent = j.error; errorEl.style.display = 'block'; }
});

document.getElementById('restrictions-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    data.weeklyHoursTarget = parseFloat(data.weeklyHoursTarget);
    data.maxConsecutiveHours = parseFloat(data.maxConsecutiveHours);
    const res = await fetch('/admin/schedule/' + employeeId + '/restrictions', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
    });
    if (res.ok) location.reload();
    else alert('Erreur lors de la mise à jour des contraintes');
});
</script>

<%- include('../layout/footer') %>
