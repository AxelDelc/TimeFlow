<%- include('../layout/header', { pageTitle: 'Pointages', currentPage: 'sessions', user: user }) %>

<div class="card">
    <div class="card-header">
        <span class="card-title">Tous les pointages</span>
        <span class="badge badge-blue"><%= sessions.length %> entrée<%= sessions.length > 1 ? 's' : '' %></span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Salarié</th>
                    <th>Entrée</th>
                    <th>Sortie</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                <% if (sessions.length === 0) { %>
                    <tr><td colspan="4" class="empty-state">Aucun pointage enregistré</td></tr>
                <% } %>
                <% sessions.forEach(s => { %>
                    <tr>
                        <td>
                            <div class="employee-cell">
                                <div class="user-avatar avatar-dark avatar-sm">
                                    <%= s.user.name.charAt(0).toUpperCase() %>
                                </div>
                                <span><%= s.user.name %></span>
                            </div>
                        </td>
                        <td><%= s.startTime %></td>
                        <td><%= s.endTime || '—' %></td>
                        <td>
                            <% if (!s.endTime) { %>
                                <span class="badge badge-green"><span class="badge-dot"></span>En cours</span>
                            <% } else { %>
                                <span class="badge badge-gray">Terminé</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../layout/footer') %>
