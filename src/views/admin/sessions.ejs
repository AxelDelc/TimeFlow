<%- include('../layout/header', { pageTitle: 'Pointages', currentPage: 'sessions', user: user }) %>

<div class="card">
    <div class="card-header">
        <span class="card-title">Tous les pointages</span>
        <span class="badge badge-blue"><%= sessions.length %> entrée<%= sessions.length > 1 ? 's' : '' %></span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Salarié</th>
                    <th>Entrée</th>
                    <th>Sortie</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                <% if (sessions.length === 0) { %>
                    <tr><td colspan="4" class="empty-state">Aucun pointage enregistré</td></tr>
                <% } %>
                <% sessions.forEach(s => { %>
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:9px;">
                                <div class="user-avatar" style="background:#334155;color:#cbd5e1;width:28px;height:28px;font-size:11px;">
                                    <%= s.employee_name.charAt(0).toUpperCase() %>
                                </div>
                                <span><%= s.employee_name %></span>
                            </div>
                        </td>
                        <td><%= s.start_time %></td>
                        <td><%= s.end_time || '—' %></td>
                        <td>
                            <% if (!s.end_time) { %>
                                <span class="badge badge-green"><span class="badge-dot"></span>En cours</span>
                            <% } else { %>
                                <span class="badge badge-gray">Terminé</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../layout/footer') %>
